# Land Registry Backend Configuration

# Fabric Network
CHANNEL_NAME=landregistrychannel
CHAINCODE_NAME=land-token

# Connection profile paths (relative to backend root)
CONNECTION_PROFILE_REVENUEDEPT=../network/land-registry-network/organizations/peerOrganizations/revenuedept.landregistry.com/connection-revenuedept.json
CONNECTION_PROFILE_REGIONALOFFICE=../network/land-registry-network/organizations/peerOrganizations/regionaloffice.landregistry.com/connection-regionaloffice.json

# Wallet path
WALLET_PATH=./wallet

# Fabric CA
CA_REVENUEDEPT_URL=https://localhost:7054
CA_REGIONALOFFICE_URL=https://localhost:8054
CA_TLS_CERT_REVENUEDEPT=../network/land-registry-network/organizations/fabric-ca/revenuedept/ca-cert.pem
CA_TLS_CERT_REGIONALOFFICE=../network/land-registry-network/organizations/fabric-ca/regionaloffice/ca-cert.pem

# Supabase (Web2 read cache - ownership updates from blockchain only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Server
PORT=3000
